# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hugging Face (Kimi K2)
HUGGINGFACE_API_KEY=your-hf-api-key
KIMI_MODEL=moonshotai/Kimi-K2-Instruct

# Splunk
SPLUNK_HOST=your-splunk-host
SPLUNK_PORT=8089
SPLUNK_TOKEN=your-splunk-hec-token

# Threat Intel
VIRUSTOTAL_API_KEY=your-vt-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# Webhook
WEBHOOK_SECRET=your-random-secret-here

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
RESEND_API_KEY=re_your_resend_api_key         # for email via Resend
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Scheduler
SCHED_INTERVAL_MS=60000    # how often agent checks schedules (ms)
POLL_INTERVAL_MS=30000     # how often agent polls for new alerts (ms)

# Demo seeding
ALLOW_SEED=true
SEED_SECRET=optional-extra-protection

# App URLs
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
