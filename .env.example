# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Also needed for browser/SSR
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Hugging Face / Kimi K2 ───────────────────────────────────────
HUGGINGFACE_API_KEY=hf_your_api_key_here
KIMI_MODEL=moonshotai/Kimi-K2-Instruct

# ── Splunk ───────────────────────────────────────────────────────
SPLUNK_HOST=your-splunk-host.example.com
SPLUNK_PORT=8089
SPLUNK_TOKEN=your-splunk-hec-token

# ── Webhook auth ─────────────────────────────────────────────────
WEBHOOK_SECRET=change-me-to-a-random-32-char-string

# ── Threat Intel (optional but recommended) ──────────────────────
VIRUSTOTAL_API_KEY=your-vt-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# ── Notifications ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
RESEND_API_KEY=re_your_resend_key               # email via Resend
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app # used in notification links

# ── Agent tuning ─────────────────────────────────────────────────
POLL_INTERVAL_MS=30000       # alert poll loop interval (default 30s)
SCHED_INTERVAL_MS=60000      # scheduler check interval (default 60s)
HEARTBEAT_INTERVAL_MS=30000  # heartbeat emit interval (default 30s)
AGENT_VERSION=1.0.0

# ── Demo / dev ───────────────────────────────────────────────────
ALLOW_SEED=true              # set true on staging/demo; NEVER in prod
SEED_SECRET=optional-seed-password

# ── Testing (Playwright) ─────────────────────────────────────────
TEST_USER_EMAIL=analyst@yourapp.com
TEST_USER_PASSWORD=your-test-password
PLAYWRIGHT_BASE_URL=http://localhost:3000
